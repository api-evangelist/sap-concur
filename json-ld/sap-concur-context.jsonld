          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "submitDate": {
          "@id": "concur:submitDate",
          "@type": "xsd:dateTime"
        },
        "reportVersion": {
          "@id": "schema:version",
          "@type": "xsd:integer"
        },
        "customData": {
          "@id": "concur:customData",
          "@type": "@id",
          "@container": "@set"
        },
        "expenses": {
          "@id": "concur:hasExpense",
          "@type": "@id",
          "@container": "@set"
        },
        "allocations": {
          "@id": "concur:hasAllocation",
